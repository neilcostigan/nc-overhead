{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/aircraft.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=1, stale-while-revalidate=5" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
